{
  "name": "@azure-tools/oav-runner",
  "private": true,
  "type": "module",
  "main": "src/main.ts",
  "bin": {
    "oav-runner": "cmd/oav-runner.js"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "check": "pnpm build && pnpm lint && pnpm format:check && pnpm test:ci",
    "format": "prettier . --ignore-path ../.prettierignore --write",
    "format:check": "prettier . --ignore-path ../.prettierignore --check",
    "format:check:ci": "prettier . --ignore-path ../.prettierignore --check --log-level debug",
    "lint": "cross-env DEBUG=eslint:eslint,eslint:linter eslint",
    "test": "vitest",
    "test:ci": "vitest run --coverage --reporter=verbose"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@azure-tools/specs-shared": "workspace:*",
    "js-yaml": "catalog:",
    "oav": "4.0.4",
    "simple-git": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "cross-env": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-organize-imports": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:",
    "@types/js-yaml": "catalog:"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "version": "0.0.0"
}
