{
  "name": "@azure-tools/suppressions",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "get-suppressions": "cmd/get-suppressions.js"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "check": "pnpm build && pnpm lint && pnpm format:check && pnpm test:ci",
    "format": "prettier . --ignore-path ../.prettierignore --write",
    "format:check": "prettier . --ignore-path ../.prettierignore --check",
    "format:check:ci": "prettier . --ignore-path ../.prettierignore --check --log-level debug",
    "lint": "cross-env DEBUG=eslint:eslint,eslint:linter eslint",
    "test": "vitest",
    "test:ci": "vitest run --coverage --reporter=verbose"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "minimatch": "^10.0.1",
    "yaml": "^2.4.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@azure-tools/specs-shared": "workspace:*",
    "@eslint/js": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "cross-env": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-organize-imports": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  },
  "version": "0.0.0"
}
