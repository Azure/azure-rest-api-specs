{
  "name": "@azure-tools/lint-diff",
  "private": true,
  "type": "module",
  "main": "src/lint-diff.ts",
  "bin": {
    "lint-diff": "cmd/lint-diff.js"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "check": "pnpm build && pnpm lint && pnpm format:check && pnpm test:ci",
    "clean": "rm -rf dist && rm -rf node_modules",
    "format": "prettier . --ignore-path ../.prettierignore --write",
    "format:check": "prettier . --ignore-path ../.prettierignore --check",
    "format:check:ci": "prettier . --ignore-path ../.prettierignore --check --log-level debug",
    "lint": "cross-env DEBUG=eslint:eslint,eslint:linter eslint",
    "test": "vitest",
    "test:ci": "vitest run --coverage --reporter=verbose"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "dependencies": {
    "@apidevtools/json-schema-ref-parser": "catalog:",
    "@azure-tools/specs-shared": "workspace:*",
    "@microsoft.azure/openapi-validator": "2.2.4",
    "@microsoft.azure/openapi-validator-core": "1.0.7",
    "@microsoft.azure/openapi-validator-rulesets": "2.2.6",
    "autorest": "catalog:",
    "change-case": "^5.4.4",
    "deep-eql": "^5.0.2",
    "marked": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@types/deep-eql": "^4.0.2",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "cross-env": "catalog:",
    "eslint": "catalog:",
    "execa": "^9.5.2",
    "memfs": "^4.17.0",
    "prettier": "catalog:",
    "prettier-plugin-organize-imports": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  },
  "version": "0.0.0"
}
