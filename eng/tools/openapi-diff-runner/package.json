{
  "name": "@azure-tools/openapi-diff-runner",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "openapi-diff-runner": "cmd/openapi-diff-runner.js"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "format": "prettier . --ignore-path ../.prettierignore --write",
    "format:check": "prettier . --ignore-path ../.prettierignore --check",
    "format:check:ci": "prettier . --ignore-path ../.prettierignore --check --log-level debug",
    "test": "vitest",
    "test:ci": "vitest run --coverage --reporter=verbose"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@azure-tools/specs-shared": "workspace:*",
    "@azure/oad": "0.12.4"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-organize-imports": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "version": "0.0.0"
}
