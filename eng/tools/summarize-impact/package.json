{
  "name": "@azure-tools/summarize-impact",
  "private": true,
  "type": "module",
  "main": "src/main.ts",
  "bin": {
    "summarize-impact": "cmd/summarize-impact.js"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "format": "prettier . --ignore-path ../.prettierignore --write",
    "format:check": "prettier . --ignore-path ../.prettierignore --check",
    "format:check:ci": "prettier . --ignore-path ../.prettierignore --check --log-level debug",
    "test": "vitest --run",
    "test:ci": "vitest run --coverage --reporter=verbose"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@azure-tools/openapi-tools-common": "^1.2.2",
    "@azure-tools/specs-shared": "workspace:*",
    "@azure/openapi-markdown": "0.9.4",
    "@octokit/rest": "^22.0.0",
    "commonmark": "0.31.2",
    "glob": "^13.0.0",
    "js-yaml": "catalog:",
    "lodash": "^4.17.20",
    "simple-git": "catalog:"
  },
  "devDependencies": {
    "@types/commonmark": "0.27.10",
    "@types/lodash": "^4.14.161",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-organize-imports": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "@types/js-yaml": "catalog:"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "version": "0.0.0"
}
