{
  "name": "@azure-tools/tsp-client-tests",
  "private": true,
  "type": "module",
  "devDependencies": {
    "@azure-tools/specs-shared": "workspace:*",
    "@eslint/js": "catalog:",
    "@types/node": "catalog:",
    "cross-env": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-organize-imports": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "check": "pnpm build && pnpm lint && pnpm format:check && pnpm test:ci",
    "format": "prettier . --ignore-path ../.prettierignore --write",
    "format:check": "prettier . --ignore-path ../.prettierignore --check",
    "format:check:ci": "prettier . --ignore-path ../.prettierignore --check --log-level debug",
    "lint": "cross-env DEBUG=eslint:eslint,eslint:linter eslint",
    "test": "vitest",
    "test:ci": "vitest run --reporter=verbose"
  },
  "engines": {
    "node": ">=24.14.1"
  },
  "version": "0.0.0"
}
