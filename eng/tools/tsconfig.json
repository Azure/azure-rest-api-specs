{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "es2024",
    "module": "NodeNext",
    // override "importHelpers:true" in root tsconfig.json
    "importHelpers": false,
    "noEmit": true,
    "erasableSyntaxOnly": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "allowJs": true,
    // default changed to [] (empty array) in typescript v6
    "types": ["node"],
  },
  "include": [
    "lint-diff/src/**/*.ts",
    "lint-diff/test/**/*.ts",
    "oav-runner/src/**/*.ts",
    "oav-runner/test/**/*.ts",
    "openapi-diff-runner/src/**/*.ts",
    "openapi-diff-runner/test/**/*.ts",
    "sdk-suppressions/src/**/*.ts",
    "sdk-suppressions/test/**/*.ts",
    "spec-gen-sdk-runner/src/**/*.ts",
    "spec-gen-sdk-runner/test/**/*.ts",
    "summarize-impact/src/**/*.ts",
    "summarize-impact/test/**/*.ts",
    "suppressions/src/**/*.ts",
    "suppressions/test/**/*.ts",
    "tsp-client-tests/src/**/*.ts",
    "tsp-client-tests/test/**/*.ts",
    "typespec-migration-validation/src/**/*.ts",
    "typespec-migration-validation/test/**/*.ts",
    "typespec-requirement/src/**/*.ts",
    "typespec-requirement/test/**/*.ts",
    "typespec-validation/src/**/*.ts",
    "typespec-validation/test/**/*.ts",
  ],
}
