{
  "name": "@azure-tools/sdk-suppressions",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "version": "1.0.0",
  "bin": {
    "get-sdk-suppressions-label": "cmd/sdk-suppressions-label.js"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "format": "prettier . --ignore-path ../.prettierignore --write",
    "format:check": "prettier . --ignore-path ../.prettierignore --check",
    "format:check:ci": "prettier . --ignore-path ../.prettierignore --check --log-level debug",
    "test": "vitest",
    "test:ci": "vitest run --coverage --reporter=verbose"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@azure-tools/specs-shared": "workspace:*",
    "ajv": "^8.17.1",
    "debug": "catalog:",
    "lodash": "^4.17.20",
    "simple-git": "catalog:",
    "yaml": "^2.4.2"
  },
  "devDependencies": {
    "@types/debug": "catalog:",
    "@types/lodash": "^4.14.161",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-organize-imports": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
