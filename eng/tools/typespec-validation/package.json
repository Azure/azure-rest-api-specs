{
  "name": "@azure-tools/typespec-validation",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "tsv": "cmd/tsv.js"
  },
  "dependencies": {
    "@azure-tools/specs-shared": "workspace:*",
    "debug": "catalog:",
    "globby": "^16.0.0",
    "picocolors": "^1.1.1",
    "simple-git": "catalog:",
    "@azure-tools/suppressions": "workspace:*",
    "strip-ansi": "^7.1.0",
    "yaml": "^2.4.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@types/debug": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "cross-env": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-organize-imports": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "check": "pnpm build && pnpm lint && pnpm format:check && pnpm test:ci",
    "format": "prettier . --ignore-path ../.prettierignore --write",
    "format:check": "prettier . --ignore-path ../.prettierignore --check",
    "format:check:ci": "prettier . --ignore-path ../.prettierignore --check --log-level debug",
    "lint": "cross-env DEBUG=eslint:eslint,eslint:linter eslint",
    "test": "vitest",
    "test:ci": "vitest run --coverage --reporter=verbose"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "version": "0.0.0"
}
