{
  "name": "TypeSpec Dev Container",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:dev-24",
  // Default is 2 cores which is too slow for this codebase
  "hostRequirements": {"cpus": 4},
  "postCreateCommand": "npm install -g pnpm@11.5.1 && pnpm ci",
  "customizations": {
    "vscode": {
      // Keep in sync with .vscode/extensions.json
      "extensions": [
        "EditorConfig.EditorConfig",
        "esbenp.prettier-vscode",
        "typespec.typespec-vscode",
        "docsmsft.docs-authoring-pack"
      ]
    }
  }
}
