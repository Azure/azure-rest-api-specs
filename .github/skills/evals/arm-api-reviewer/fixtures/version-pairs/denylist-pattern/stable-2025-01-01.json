{
  "swagger": "2.0",
  "info": {
    "title": "DenylistPatternTestClient",
    "version": "2025-01-01",
    "description": "Denylist pattern test — new version. The policyName path parameter still carries the denylist pattern (pre-existing from 2024-01-01). The new description property also uses a denylist pattern (newly added — blocking)."
  },
  "host": "management.azure.com",
  "schemes": ["https"],
