      "type": "object",
      "description": "Properties of a policy resource.",
      "properties": {
        "displayName": {
          "type": "string",
          "description": "The display name of the policy.",
          "pattern": "^[^<>*%&:\\?.+/]*[^<>*%&:\\?.+/ ]+$",
          "maxLength": 128
        },
        "description": {
          "type": "string",
          "description": "The description of the policy.",
          "pattern": "^[^\\x00-\\x1F\\x7F]+$",
          "maxLength": 512
        },
        "provisioningState": {
          "type": "string",
          "readOnly": true,
          "description": "The provisioning state of the policy resource.",
          "enum": ["Succeeded", "Failed", "Canceled", "Creating", "Updating", "Deleting"],
          "x-ms-enum": {
            "name": "ProvisioningState",
            "modelAsString": true
          }
        }
