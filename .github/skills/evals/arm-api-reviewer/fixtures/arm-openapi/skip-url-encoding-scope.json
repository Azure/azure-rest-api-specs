  "parameters": {
    "ScopeParameter": {
      "name": "scope",
      "in": "path",
      "required": true,
      "type": "string",
      "x-ms-skip-url-encoding": true,
      "x-ms-parameter-location": "method",
      "description": "The fully-qualified ARM resource scope at which to apply the lock. The value may contain multiple path segments (e.g., subscriptions/{sub}/resourceGroups/{rg} or subscriptions/{sub}/resourceGroups/{rg}/providers/{ns}/{type}/{name}), so URL encoding must be skipped to preserve the embedded slash characters."
    },
    "LockNameParameter": {
      "name": "lockName",
      "in": "path",
      "required": true,
      "type": "string",
      "x-ms-parameter-location": "method",
      "description": "The name of the lock.",
      "pattern": "^[A-Za-z0-9_.-]{1,260}$"
    }
  },
  "definitions": {
    "Lock": {
      "type": "object",
      "description": "A management lock applied at a specified scope.",
      "properties": {
        "id": {
          "type": "string",
          "description": "The fully qualified ARM resource ID of the lock.",
          "readOnly": true
        },
        "name": {
          "type": "string",
          "description": "The name of the lock.",
          "readOnly": true
        },
        "type": {
          "type": "string",
          "description": "The resource type of the lock.",
          "readOnly": true
        },
        "systemData": {
          "$ref": "../../../../../common-types/resource-management/v5/types.json#/definitions/systemData"
        },
        "properties": {
          "$ref": "#/definitions/LockProperties",
          "description": "The lock properties.",
          "x-ms-client-flatten": false
        }
      },
      "x-ms-azure-resource": true
    },
    "LockProperties": {
      "type": "object",
      "description": "Properties of a management lock.",
      "required": ["level"],
      "properties": {
        "level": {
          "type": "string",
          "description": "The lock level that prevents modification or deletion of the locked resource.",
          "enum": ["NotSpecified", "CanNotDelete", "ReadOnly"],
          "x-ms-enum": {
            "name": "LockLevel",
            "modelAsString": true
          }
        },
        "notes": {
          "type": "string",
          "description": "Notes about the lock. Maximum of 512 characters.",
          "maxLength": 512
        },
        "provisioningState": {
          "type": "string",
          "description": "The provisioning state of the lock.",
          "readOnly": true,
          "enum": ["Succeeded", "Failed", "Canceled"],
          "x-ms-enum": {
            "name": "ProvisioningState",
            "modelAsString": true
          }
        }
      }
    },
    "LockListResult": {
      "type": "object",
      "description": "A list of management locks.",
      "properties": {
        "value": {
          "type": "array",
          "items": { "$ref": "#/definitions/Lock" },
          "description": "The list of locks."
        },
        "nextLink": {
          "type": "string",
          "format": "uri",
          "readOnly": true,
          "description": "The URI to fetch the next page of results."
        }
      }
    }
