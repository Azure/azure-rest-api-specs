{
  "swagger": "2.0",
  "info": {
    "title": "ScopeExtensionClient",
    "version": "2025-01-01",
    "description": "Extension resource provider that uses a {scope} path parameter with x-ms-skip-url-encoding. This is a true-negative fixture: the extension is legitimately applied to a multi-segment ARM scope parameter with a justifying description."
  },
  "host": "management.azure.com",
  "schemes": ["https"],
  "consumes": ["application/json"],
  "produces": ["application/json"],
