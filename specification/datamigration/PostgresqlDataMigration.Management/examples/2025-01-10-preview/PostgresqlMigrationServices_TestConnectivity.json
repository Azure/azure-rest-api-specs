{
  "title": "Test connectivity to source and target databases",
  "operationId": "PostgresqlMigrationServices_TestConnectivity",
  "parameters": {
    "subscriptionId": "12345678-1234-1234-1234-123456789012",
    "resourceGroupName": "my-rg",
    "serviceName": "myMigrationService",
    "api-version": "2025-01-10-preview",
    "body": {
      "source": {
        "engine": "oracle",
        "serverResourceId": null,
        "connectionEndPoints": [
          {
            "connectionName": "sourceConnection1",
            "hostName": "source-db.company.com",
            "port": 1521,
            "serviceName": "PRODSCHEMA1",
            "databaseName": null,
            "credentials": {
              "authenticationMethod": "password",
              "userName": "migration_user",
              "password": "encrypted_password"
            },
            "ssl": {
              "mode": "require"
            }
          }
        ]
      },
      "target": {
        "engine": "azure_postgres_flexible",
        "serverResourceId": "/subscriptions/12345678-1234-1234-1234-123456789012/resourceGroups/my-rg/providers/Microsoft.DBforPostgreSQL/flexibleServers/myServer",
        "connectionEndPoints": [
          {
            "connectionName": "targetConnection1",
            "hostName": "target-server1.postgres.database.azure.com",
            "port": 5432,
            "serviceName": null,
            "databaseName": "target_db",
            "credentials": {
              "authenticationMethod": "password",
              "userName": "migration_user",
              "password": "encrypted_password"
            },
            "ssl": {
              "mode": "require"
            }
          }
        ]
      },
      "computeProfile": {
        "computeSubnetResourceId": "/subscriptions/12345678-1234-1234-1234-123456789012/resourceGroups/my-rg/providers/Microsoft.Network/virtualNetworks/myVnet/subnets/mySubnet"
      }
    }
  },
  "responses": {
    "202": {
      "description": "Accepted - connectivity test is in progress",
      "headers": {
        "Location": "https://management.azure.com/subscriptions/12345678-1234-1234-1234-123456789012/providers/Microsoft.DataMigration/locations/eastus2/operationTypes/testConnectivity/operationResults/1234-abcd-1234-abcd1234abcd?api-version=2025-01-10-preview",
        "Retry-After": "10"
      }
    },
    "200": {
      "description": "Success - connectivity test completed",
      "body": {
        "requestId": "1234-abcd-1234-abcd1234abcd",
        "properties": {
          "source": [
            {
              "connectionName": "sourceConnection1",
              "connectionStatus": "Succeeded",
              "errors": []
            }
          ],
          "target": [
            {
              "connectionName": "targetConnection1",
              "connectionStatus": "Succeeded",
              "errors": []
            }
          ]
        }
      }
    }
  }
}
