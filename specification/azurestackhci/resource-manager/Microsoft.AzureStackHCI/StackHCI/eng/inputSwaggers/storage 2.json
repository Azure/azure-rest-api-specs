  "definitions": {
    "Disk": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "readOnly": true,
          "description": "Fully qualified resource ID for the resource."
        },
        "name": {
          "type": "string",
          "readOnly": true,
          "description": "The name of the resource."
        },
        "type": {
          "type": "string",
          "readOnly": true,
          "description": "The type of the resource."
        },
        "properties": {
          "$ref": "#/definitions/DiskProperties"
        }
      }
    },
    "DiskProperties": {
      "type": "object",
      "description": "The properties of a disk.",
      "properties": {
        "diskConfiguration": {
          "$ref": "#/definitions/DiskConfiguration",
          "description": "The authoritative desired configuration for this disk. Persisted in cloud until changed."
        },
        "reportedProperties": {
          "$ref": "#/definitions/DiskReportedProperties",
          "description": "The actual state of the disk as reported by the device.",
          "readOnly": true
        },
        "provisioningState": {
          "$ref": "#/definitions/ProvisioningState",
          "readOnly": true
        }
      }
    },
    "DiskConfiguration": {
      "type": "object",
      "description": "Desired configuration for a disk.",
      "properties": {
        "volumes": {
          "type": "array",
          "description": "List of desired volumes on this disk.",
          "items": {
            "$ref": "#/definitions/DiskVolumeConfiguration"
          }
        }
      }
    },
    "DiskVolumeConfiguration": {
      "type": "object",
      "description": "Configuration for a volume.",
      "properties": {
        "sizeInBytes": {
          "type": "integer",
          "format": "int64",
          "description": "Size of the volume in bytes."
        },
        "path": {
          "type": "string",
          "description": "Mount path for the volume (e.g., /data or D:\\data)."
        },
        "fileSystem": {
          "type": "string",
          "description": "File system type to format the volume with. Optional - defaults to ext4 on Linux systems, NTFS on Windows systems.",
          "enum": ["ext4", "xfs", "NTFS", "ReFS"]
        }
      },
      "required": ["sizeInBytes", "path"]
    },
    "DiskReportedProperties": {
      "type": "object",
      "description": "The actual state of the disk as reported by the device.",
      "properties": {
        "diskName": {
          "type": "string",
          "description": "The actual disk name as reported by the operating system (e.g., /dev/sda on Linux, PhysicalDrive0 on Windows). This preserves the original name including characters not allowed in ARM resource names.",
          "readOnly": true
        },
        "model": {
          "type": "string",
          "description": "Represents the model number of the hardware.",
          "readOnly": true
        },
        "manufacturer": {
          "type": "string",
          "description": "The name of the company responsible for the hardware.",
          "readOnly": true
        },
        "serialNumber": {
          "type": "string",
          "description": "Serial number.",
          "readOnly": true
        },
        "firmwareVersion": {
          "type": "string",
          "description": "A string representation of the firmware revision.",
          "readOnly": true
        },
        "sizeInBytes": {
          "type": "integer",
          "format": "int64",
          "description": "Size in bytes.",
          "readOnly": true
        },
        "type": {
          "type": "string",
          "description": "Type of the disk.",
          "enum": [
            "Unknown",
            "SCM",
            "NVMe",
            "SATA",
            "SSD",
            "HDD",
            "Virtual",
            "Other"
          ],
          "readOnly": true
        },
        "busLocation": {
          "type": "string",
          "description": "The bus location of the disk (e.g., PCI bus address).",
          "readOnly": true
        },
        "unallocatedSizeInBytes": {
          "type": "integer",
          "format": "int64",
          "description": "Unallocated space on the disk in bytes.",
          "readOnly": true
        },
        "state": {
          "type": "string",
          "description": "The current state of the disk.",
          "enum": [
            "Online",
            "Offline",
            "Failed",
            "Missing",
            "Unknown"
          ],
          "readOnly": true
        },
        "volumes": {
          "type": "array",
          "description": "List of volumes currently present on this disk as reported by the device.",
          "items": {
            "$ref": "#/definitions/DiskVolumeReportedProperties"
          },
          "readOnly": true
        }
      }
    },
    "DiskVolumeReportedProperties": {
      "type": "object",
      "description": "Reported properties of a volume on the disk.",
      "properties": {
        "volumeId": {
          "type": "string",
          "description": "Unique identifier for the volume within the operating system (e.g., sda1, sdb1 on Linux; unique GUID or identifier on Windows).",
          "readOnly": true
        },
        "volumeNumber": {
          "type": "integer",
          "format": "int32",
          "description": "The volume/partition number (e.g., 1 for sda1, 2 for sda2).",
          "readOnly": true
        },
        "sizeInBytes": {
          "type": "integer",
          "format": "int64",
          "description": "Size of the volume in bytes.",
          "readOnly": true
        },
        "path": {
          "type": "string",
          "description": "Mount path for the volume (e.g., /data or D:\\data). Null if not mounted.",
          "readOnly": true
        },
        "fileSystem": {
          "type": "string",
          "description": "File system type (e.g., ext4, xfs, NTFS, ReFS). Null if not formatted.",
          "readOnly": true
        }
      }
    },
    "DiskListResult": {
      "type": "object",
      "properties": {
        "value": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Disk"
          }
        },
        "nextLink": {
          "type": "string",
          "description": "The URL to get the next set of results."
        }
      }
    },
    "Volume": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "readOnly": true,
          "description": "Fully qualified resource ID for the resource."
        },
        "name": {
          "type": "string",
          "readOnly": true,
          "description": "The name of the resource."
        },
        "type": {
          "type": "string",
          "readOnly": true,
          "description": "The type of the resource."
        },
        "properties": {
          "$ref": "#/definitions/VolumeProperties"
        }
      }
    },
    "VolumeProperties": {
      "type": "object",
      "description": "The properties of a volume.",
      "properties": {
        "volumeConfiguration": {
          "$ref": "#/definitions/VolumeConfiguration",
          "description": "The authoritative desired configuration for this volume. Currently empty but reserved for future use."
        },
        "reportedProperties": {
          "$ref": "#/definitions/VolumeReportedProperties",
          "description": "The actual state of the volume as reported by the device.",
          "readOnly": true
        },
        "provisioningState": {
          "$ref": "#/definitions/ProvisioningState",
          "readOnly": true
        }
      }
    },
    "VolumeConfiguration": {
      "type": "object",
      "description": "Desired configuration for a volume. Currently empty but reserved for future use.",
      "properties": {}
    },
    "VolumeReportedProperties": {
      "type": "object",
      "description": "The actual state of the volume as reported by the device.",
      "properties": {
        "partitionId": {
          "type": "string",
          "description": "Unique identifier for the partition (e.g., GPT GUID). Immutable and stable.",
          "readOnly": true
        },
        "offsetInBytes": {
          "type": "integer",
          "format": "int64",
          "description": "The byte offset of the partition start. Used to determine physical order and visualization.",
          "readOnly": true
        },
        "name": {
          "type": "string",
          "description": "Label of the volume (e.g., Volume1).",
          "readOnly": true
        },
        "path": {
          "type": "string",
          "description": "Access path for the volume (e.g., C:\\ClusterStorage\\Volume1).",
          "readOnly": true
        },
        "parentDiskId": {
          "type": "string",
          "description": "The ARM resource ID of the parent disk that contains this volume.",
          "readOnly": true
        },
        "isBoot": {
          "type": "boolean",
          "description": "Indicates if this volume is a boot volume.",
          "readOnly": true
        },
        "sizeInBytes": {
          "type": "integer",
          "format": "int64",
          "description": "Total size of the volume in bytes.",
          "readOnly": true
        },
        "sizeRemainingInBytes": {
          "type": "integer",
          "format": "int64",
          "description": "Available space on the volume in bytes.",
          "readOnly": true
        },
        "fileSystem": {
          "type": "string",
          "description": "File system on the volume. Common values include NTFS, ReFS (Windows), ext4, xfs (Linux).",
          "readOnly": true
        }
      }
    },
    "VolumeListResult": {
      "type": "object",
      "properties": {
        "value": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Volume"
          }
        },
        "nextLink": {
          "type": "string",
          "description": "The URL to get the next set of results."
        }
      }
    },
    "DiskJob": {
      "type": "object",
      "description": "Disk Job resource",
      "properties": {
        "id": {
          "type": "string",
          "readOnly": true,
          "description": "Fully qualified resource ID for the resource."
        },
        "name": {
          "type": "string",
          "readOnly": true,
          "description": "The name of the resource."
        },
        "type": {
          "type": "string",
          "readOnly": true,
          "description": "The type of the resource."
        },
        "properties": {
          "$ref": "#/definitions/DiskJobProperties",
          "description": "The resource-specific properties for this resource."
        }
      }
    },
    "DiskJobListResult": {
      "type": "object",
      "description": "The response of a DiskJob list operation.",
      "properties": {
        "value": {
          "type": "array",
          "description": "The DiskJob items on this page",
          "items": {
            "$ref": "#/definitions/DiskJob"
          }
        },
        "nextLink": {
          "type": "string",
          "description": "The URL to get the next set of results."
        }
      },
      "required": ["value"]
    },
    "DiskJobProperties": {
      "type": "object",
      "description": "Disk Job properties",
      "properties": {
        "jobType": {
          "$ref": "#/definitions/DiskJobType",
          "description": "Job Type to support polymorphic resource.",
          "x-ms-mutability": ["read", "create"]
        },
        "provisioningState": {
          "$ref": "#/definitions/ProvisioningState",
          "description": "Job provisioning state",
          "readOnly": true
        },
        "jobId": {
          "type": "string",
          "description": "Unique, immutable job id.",
          "readOnly": true
        },
        "startTimeUtc": {
          "type": "string",
          "format": "date-time",
          "description": "The UTC date and time at which the job started.",
          "readOnly": true
        },
        "endTimeUtc": {
          "type": "string",
          "format": "date-time",
          "description": "The UTC date and time at which the job completed.",
          "readOnly": true
        },
        "status": {
          "$ref": "#/definitions/JobStatus",
          "description": "Status of disk job.",
          "readOnly": true
        },
        "error": {
          "$ref": "#/definitions/ErrorDetail",
          "description": "Error details if job failed.",
          "readOnly": true
        },
        "reportedProperties": {
          "$ref": "#/definitions/DiskJobReportedProperties",
          "description": "Properties reported by the job execution on the device.",
          "readOnly": true
        }
      },
      "discriminator": "jobType",
      "required": ["jobType"]
    },
    "DiskJobType": {
      "type": "string",
      "description": "Job Type supported for disk operations.",
      "enum": ["CreateVolume", "DeleteVolume", "SyncConfiguration"],
      "x-ms-enum": {
        "name": "DiskJobType",
        "modelAsString": true,
        "values": [
          {
            "name": "CreateVolume",
            "value": "CreateVolume",
            "description": "Job to create a volume on the disk."
          },
          {
            "name": "DeleteVolume",
            "value": "DeleteVolume",
            "description": "Job to delete a volume from the disk."
          },
          {
            "name": "SyncConfiguration",
            "value": "SyncConfiguration",
            "description": "Job to resolve configuration drift between desired state (ARM) and reported state (device)."
          }
        ]
      }
    },
    "ProvisioningState": {
      "type": "string",
      "description": "Provisioning state of the resource.",
      "enum": ["Succeeded", "Failed", "Canceled", "Provisioning", "Updating", "Deleting", "Accepted"],
      "x-ms-enum": {
        "name": "ProvisioningState",
        "modelAsString": true
      },
      "readOnly": true
    },
    "JobStatus": {
      "type": "string",
      "description": "Status of the job execution.",
      "enum": ["NotStarted", "Running", "Succeeded", "Failed", "Canceled"],
      "x-ms-enum": {
        "name": "JobStatus",
        "modelAsString": true,
        "values": [
          {
            "name": "NotStarted",
            "value": "NotStarted",
            "description": "Job has not started yet."
          },
          {
            "name": "Running",
            "value": "Running",
            "description": "Job is currently running."
          },
          {
            "name": "Succeeded",
            "value": "Succeeded",
            "description": "Job completed successfully."
          },
          {
            "name": "Failed",
            "value": "Failed",
            "description": "Job failed to complete."
          },
          {
            "name": "Canceled",
            "value": "Canceled",
            "description": "Job was canceled."
          }
        ]
      },
      "readOnly": true
    },
