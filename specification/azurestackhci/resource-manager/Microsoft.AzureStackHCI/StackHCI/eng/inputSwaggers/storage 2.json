          { "$ref": "#/parameters/EdgeMachineName" },
          { "$ref": "#/parameters/DiskName" },
          { "$ref": "#/parameters/ApiVersion" },
          {
            "name": "disk",
            "in": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/Disk" }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "schema": { "$ref": "#/definitions/Disk" }
          },
          "201": {
            "description": "Created",
            "schema": { "$ref": "#/definitions/Disk" }
          }
        }
      },
      "delete": {
        "operationId": "Disks_Delete",
        "parameters": [
          { "$ref": "#/parameters/SubscriptionId" },
          { "$ref": "#/parameters/ResourceGroupName" },
          { "$ref": "#/parameters/EdgeMachineName" },
          { "$ref": "#/parameters/DiskName" },
          { "$ref": "#/parameters/ApiVersion" }
