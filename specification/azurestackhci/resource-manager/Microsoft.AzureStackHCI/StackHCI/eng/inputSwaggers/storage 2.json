    "/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.AzureStackHCI/clusters/{clusterName}/disks/{diskName}": {
      "get": {
        "operationId": "Disks_GetForCluster",
        "parameters": [
          { "$ref": "#/parameters/SubscriptionId" },
          { "$ref": "#/parameters/ResourceGroupName" },
          { "$ref": "#/parameters/ClusterName" },
          { "$ref": "#/parameters/DiskName" },
          { "$ref": "#/parameters/ApiVersion" }
