          },
          "default": {
            "description": "Error response",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          }
        }
      },
      "put": {
        "operationId": "DiskJobs_CreateOrUpdate",
        "description": "Create a DiskJob",
        "x-ms-long-running-operation": true,
        "x-ms-long-running-operation-options": {
          "final-state-via": "azure-async-operation"
        },
        "parameters": [
          { "$ref": "#/parameters/SubscriptionId" },
          { "$ref": "#/parameters/ResourceGroupName" },
          { "$ref": "#/parameters/EdgeMachineName" },
          { "$ref": "#/parameters/DiskName" },
          { "$ref": "#/parameters/JobName" },
          { "$ref": "#/parameters/ApiVersion" },
          {
            "name": "resource",
            "in": "body",
            "description": "Resource create parameters.",
            "required": true,
            "schema": { "$ref": "#/definitions/DiskJob" }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "schema": { "$ref": "#/definitions/DiskJob" }
          },
          "201": {
            "description": "Created",
            "schema": { "$ref": "#/definitions/DiskJob" }
          },
          "default": {
            "description": "Error response",
            "schema": { "$ref": "#/definitions/ErrorResponse" }
          }
        }
      }
    },
    "/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.AzureStackHCI/edgeMachines/{edgeMachineName}/volumes": {
