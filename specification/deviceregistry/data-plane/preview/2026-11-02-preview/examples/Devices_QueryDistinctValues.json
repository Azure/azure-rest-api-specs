{
  "operationId": "Devices_QueryDistinctValues",
  "title": "Query distinct device-class IDs in a namespace",
  "parameters": {
    "endpoint": "https://westus.api.deviceregistry.contoso.com",
    "api-version": "2026-11-02-preview",
    "namespaceUuid": "a1b2c3d4-5678-90ab-cdef-1234567890ab",
    "body": {
      "field": "properties.deviceClassId",
      "query": "WHERE groupMemberships.Contains('g-1')"
    }
  },
  "responses": {
    "200": {
      "body": {
        "value": [
          "dc-1",
          "dc-2"
        ]
      }
    }
  }
}
