          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "ExtensionRuntimeKind": {
      "type": "string",
      "description": "The backend architecture of a deployment extension runtime. This selects the\nshape of `properties.config` and is immutable after creation.",
      "enum": [
        "ContainerApps",
        "BuiltIn"
      ],
      "x-ms-enum": {
        "name": "ExtensionRuntimeKind",
        "modelAsString": true,
        "values": [
          {
            "name": "ContainerApps",
            "value": "ContainerApps",
            "description": "Customer-managed runtime hosted on Azure Container Apps. The customer\nprovides the extension binary, an Entra ID app registration, and\nconfiguration; the resource provider creates the Azure Container Apps\nresources in the customer's subscription."
          },
          {
            "name": "BuiltIn",
            "value": "BuiltIn",
            "description": "Platform-provided extension backed by a first-party service. No\ncustomer-managed binary or Azure Container Apps resources are created."
          }
        ]
      }
    },
    "ProvisioningState": {
      "type": "string",
      "description": "The provisioning state of a deployment extension runtime. The terminal\nstates are `Succeeded`, `Failed`, and `Canceled`.",
      "enum": [
        "Succeeded",
        "Failed",
        "Canceled",
        "Creating",
        "Updating",
        "Deleting"
      ],
      "x-ms-enum": {
        "name": "ProvisioningState",
        "modelAsString": true,
        "values": [
          {
            "name": "Succeeded",
            "value": "Succeeded",
            "description": "Resource has been created."
          },
          {
            "name": "Failed",
            "value": "Failed",
            "description": "Resource creation failed."
          },
          {
            "name": "Canceled",
            "value": "Canceled",
            "description": "Resource creation was canceled."
          },
          {
            "name": "Creating",
            "value": "Creating",
            "description": "The runtime is being created."
          },
          {
            "name": "Updating",
            "value": "Updating",
            "description": "The runtime is being updated."
          },
          {
            "name": "Deleting",
            "value": "Deleting",
            "description": "The runtime is being deleted."
          }
        ]
      }
    },
    "RuntimeConfig": {
      "type": "object",
      "description": "Backend configuration for a deployment extension runtime. The `kind`\ndiscriminator selects the backend architecture and the concrete shape of this\nobject.",
      "properties": {
        "kind": {
          "$ref": "#/definitions/ExtensionRuntimeKind",
          "description": "The backend architecture of the runtime. Immutable after creation.",
          "x-ms-mutability": [
            "read",
            "create"
          ]
        }
      },
      "discriminator": "kind",
      "required": [
        "kind"
      ]
    },
    "RuntimeEnvironmentVariable": {
      "type": "object",
      "description": "An environment variable set on a deployment extension runtime container.",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the environment variable.",
          "minLength": 1
        },
        "value": {
          "type": "string",
          "description": "The literal value of the environment variable. Mutually exclusive with\n`secretRef`."
        },
        "secretRef": {
          "type": "string",
          "description": "The name of a secret (from `secrets`) whose value is used for this\nenvironment variable. Mutually exclusive with `value`."
        }
      },
      "required": [
        "name"
      ]
    },
    "RuntimeNetworkProfile": {
      "type": "object",
      "description": "Virtual network integration configuration for a deployment extension\nruntime. Immutable after creation.",
      "properties": {
        "subnetId": {
          "type": "string",
          "format": "arm-id",
          "description": "The ARM resource ID of the subnet the runtime's Azure Container Apps\nenvironment is injected into. The subnet must be delegated to\n`Microsoft.App/environments`. Immutable after creation.",
          "x-ms-mutability": [
            "read",
            "create"
          ],
          "x-ms-arm-id-details": {
            "allowedResources": [
              {
                "type": "Microsoft.Network/virtualNetworks/subnets"
              }
            ]
          }
        }
      }
    },
    "RuntimeObservability": {
      "type": "object",
      "description": "Observability configuration for a deployment extension runtime.",
      "properties": {
        "workspaceId": {
          "type": "string",
          "format": "arm-id",
          "description": "The ARM resource ID of a Log Analytics workspace that receives the\nruntime's container logs.",
          "x-ms-arm-id-details": {
            "allowedResources": [
              {
                "type": "Microsoft.OperationalInsights/workspaces"
              }
            ]
          }
        }
      }
    },
    "RuntimeResources": {
      "type": "object",
      "description": "Compute resource allocation per replica for a deployment extension runtime.",
      "properties": {
        "cpu": {
          "type": "number",
          "format": "double",
          "description": "The number of vCPUs allocated per replica. Must be a valid Azure Container\nApps Consumption vCPU value (for example `0.25`, `0.5`, `1.0`, `2.0`,\n`4.0`).",
          "default": 0.5
        },
        "memory": {
          "type": "string",
          "description": "The amount of memory allocated per replica, for example `1Gi`. Must be\ncompatible with the configured `cpu` value per Azure Container Apps\nConsumption limits.",
          "default": "1Gi"
        }
      }
    },
    "RuntimeScaling": {
      "type": "object",
      "description": "Scaling configuration for a deployment extension runtime.",
      "properties": {
        "minReplicas": {
          "type": "integer",
          "format": "int32",
          "description": "The minimum number of replicas. A value of `0` enables scale-to-zero.",
