        }
      },
      "required": [
        "value"
      ]
    },
    "DeploymentExtensionRuntimeProperties": {
      "type": "object",
      "description": "Properties of a deployment extension runtime. The backend-specific\nconfiguration lives in the discriminated `config` sub-property; the remaining\nmembers are read-only outputs common to every runtime.",
