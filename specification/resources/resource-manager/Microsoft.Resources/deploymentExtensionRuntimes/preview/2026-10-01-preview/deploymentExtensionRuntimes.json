        "maxReplicas": {
          "type": "integer",
          "format": "int32",
          "description": "The maximum number of replicas.",
          "default": 5,
          "minimum": 1,
          "maximum": 30
        },
        "concurrentRequestsPerReplica": {
          "type": "integer",
          "format": "int32",
          "description": "The number of concurrent HTTP requests per replica that triggers\nscale-out.",
          "default": 10,
          "minimum": 1,
          "maximum": 500
        }
      }
    },
    "RuntimeSecret": {
      "type": "object",
      "description": "A secret injected into a deployment extension runtime container.",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the secret. Referenced from environment variables via\n`secretRef`.",
          "minLength": 1
        },
        "value": {
          "type": "string",
          "format": "password",
          "description": "The literal value of the secret. This property is write-only and is never\nreturned on read operations. Mutually exclusive with `keyVaultUri`.",
          "x-ms-mutability": [
            "update",
            "create"
          ],
          "x-ms-secret": true
        },
        "keyVaultUri": {
          "type": "string",
          "description": "The Key Vault secret URI to source the secret value from. Requires\n`identity`. Mutually exclusive with `value`."
        },
