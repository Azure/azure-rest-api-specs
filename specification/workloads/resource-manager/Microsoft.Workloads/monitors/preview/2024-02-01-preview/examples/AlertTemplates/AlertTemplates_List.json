{
  "parameters": {
    "api-version": "2024-02-01-preview",
    "providerType": "SapHana",
    "subscriptionId": "00000000-0000-0000-0000-000000000000",
    "resourceGroupName": "myResourceGroup",
    "monitorName": "mySapMonitor"
  },
  "responses": {
    "200": {
      "body": {
        "value": [
          {
            "name": "SAP HANA Health Base on CPU and Memory",
            "id": "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/myResourceGroup/providers/Microsoft.workloads/monitors/mySapMonitor/alertTemplates/myAlertTemplate1",
            "properties": {
              "templateId": "saphana-cpu-memory-health",
              "providerType": "SapHana",
              "description": "Fired when a SAP HANA database is unhealth based on CPU and memory. Looks at the 95th percentile value over 5 minutes, and if both CPU and memory exceeds 80 percent, the SAP HANA database is considered unhealthy.",
              "alertTemplateProperties": {
                "severity": 2,
                "query": "SapHana_LoadHistory_CL | where PROVIDER_INSTANCE_s == '{ProviderInstance}' | where HOST_s == '{Aggregate}' | extend memoryPercent=MEMORY_USED_d/MEMORY_SIZE_d*100 | summarize AggregatedCPU = percentile(CPU_d,95), AggregatedMemory = percentile(memoryPercent,95) by bin(TimeGenerated, 5m), HOST_s| extend AggregatedValue = iff(AggregatedCPU > 80 and AggregatedMemory > 80, 0, 1)",
                "thresholdOperator": "LessThan",
                "defaultThreshold": 1,
                "minThresholdValue": 0,
                "maxThresholdValue": 100,
                "isThresholdInputRequired": false,
                "alertUnit": "percent",
                "metricMeasurement": {
                  "thresholdOperator": "GreaterThan",
                  "threshold": 3,
                  "metricTriggerType": "Consecutive",
                  "metricColumn": "HOST_s",
                  "frequencyInMinutes": 10,
                  "timeWindowInMinutes": 45
                },
                "queryInputParameters": [
                  {
                    "parameterName": "providerInstance",
                    "parameterDefaultValue": "",
                    "parameterDescription": "The provider instance names."
                  },
                  {
                    "parameterName": "haCluster",
                    "parameterDefaultValue": "",
                    "parameterDescription": "The ha cluster instance names."
                  },
                  {
                    "parameterName": "alertThreshold",
                    "parameterDefaultValue": "1",
                    "parameterDescription": "The alert threshold value."
                  },
                  {
                    "parameterName": "laQuery",
                    "parameterType": "LogAnalyticsQuery",
                    "parameterDefaultValue": "host1",
                    "parameterDescription": "The LA query value.",
                    "parameterLaQuery": "SapHana_LoadHistory_CL | distinct HOST_s | where name in ({providerInstance})",
                    "parameterSelectionMode": "Single",
                    "parameterDisplayName": ""
                  }
                ]
              }
            }
          },
          {
            "name": "SAP HANA Health Base on CPU and Memory",
            "id": "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/myResourceGroup/providers/Microsoft.workloads/monitors/mySapMonitor/alertTemplates/myAlertTemplate2",
            "properties": {
              "templateId": "saphana-cpu-memory-health",
              "providerType": "SapHana",
              "description": "Fired when a SAP HANA database is unhealth based on CPU and memory. Looks at the 95th percentile value over 5 minutes, and if both CPU and memory exceeds 80 percent, the SAP HANA database is considered unhealthy.",
              "alertTemplateProperties": {
                "severity": 2,
                "query": "SapHana_LoadHistory_CL | where PROVIDER_INSTANCE_s == '{ProviderInstance}' | where HOST_s == '{Aggregate}' | extend memoryPercent=MEMORY_USED_d/MEMORY_SIZE_d*100 | summarize AggregatedCPU = percentile(CPU_d,95), AggregatedMemory = percentile(memoryPercent,95) by bin(TimeGenerated, 5m), HOST_s| extend AggregatedValue = iff(AggregatedCPU > 80 and AggregatedMemory > 80, 0, 1)",
                "thresholdOperator": "LessThan",
                "defaultThreshold": 1,
                "minThresholdValue": 0,
                "maxThresholdValue": 100,
                "isThresholdInputRequired": false,
                "alertUnit": "percent",
                "metricMeasurement": {
                  "thresholdOperator": "GreaterThan",
                  "threshold": 3,
                  "metricTriggerType": "Consecutive",
                  "metricColumn": "HOST_s",
                  "frequencyInMinutes": 10,
                  "timeWindowInMinutes": 45
                },
                "queryInputParameters": [
                  {
                    "parameterName": "providerInstance",
                    "parameterDefaultValue": "",
                    "parameterDescription": "The provider instance names."
                  },
                  {
                    "parameterName": "haCluster",
                    "parameterDefaultValue": "",
                    "parameterDescription": "The ha cluster instance names."
                  },
                  {
                    "parameterName": "alertThreshold",
                    "parameterDefaultValue": "1",
                    "parameterDescription": "The alert threshold value."
                  },
                  {
                    "parameterName": "laQuery",
                    "parameterType": "LogAnalyticsQuery",
                    "parameterDefaultValue": "host1",
                    "parameterDescription": "The LA query value.",
                    "parameterLaQuery": "SapHana_LoadHistory_CL | distinct HOST_s | where name in ({providerInstance})",
                    "parameterSelectionMode": "Multiple",
