{
  "operationId": "Dashboards_CreateOrUpdate",
  "title": "Create a dashboard with navigation and policy tiles.",
  "parameters": {
    "dashboardName": "testdashboard",
    "resourceGroupName": "testRG",
    "api-version": "2024-01-01-preview",
    "subscriptionId": "00000000-0000-0000-0000-000000000000",
    "resource": {
      "location": "eastus",
      "properties": {
        "title": "testdashboard",
        "pages": [
          {
            "title": "New 1",
            "tiles": [
              {
                "title": "My Arc Snapshot Tile",
                "subtitle": "My subtitle",
                "type": "NavigationTile",
                "layout": {
                  "x": 0,
                  "y": 0,
                  "width": 4,
                  "height": 4
                },
                "data": {
                  "icon": "ResourceGroups",
                  "description": "Go to resource groups"
                }
              },
              {
                "title": "ARG: Top 10 resource counts by type",
                "type": "PolicyTile",
                "layout": {
                  "x": 0,
                  "y": 0,
                  "width": 6,
                  "height": 4
                },
                "data": {
                  "kind": "policy",
                  "query": "summarize ResourceCount=count() by type | order by ResourceCount | extend ['Resource count']=ResourceCount, ['Resource type']=type | project ['Resource type'], ['Resource count'] | take 10"
                }
              }
            ]
          }
        ],
        "parameters": [
          {
            "title": "Location",
            "kind": "location",
            "parameterNames": [
              "sampleLocationParameter"
            ],
            "defaultValues": [
              "eastus"
            ],
            "showOnPages": []
          }
        ]
      }
    }
  },
