    "ProposalStatus": {
      "type": "string",
      "description": "The proposal status.",
      "enum": [
        "Draft",
        "Submitted",
        "Active",
        "Rejected",
        "Deleted",
        "Expired",
        "PurchaseInProgress",
        "Completed",
        "Ended"
      ],
      "x-ms-enum": {
        "name": "ProposalStatus",
        "modelAsString": true,
        "values": [
          {
            "name": "Draft",
            "value": "Draft",
            "description": "Draft - Initial status when a proposal is created."
          },
          {
            "name": "Submitted",
            "value": "Submitted",
            "description": "Submitted - status when a proposal is submitted for approval and waiting for approver decision."
          },
          {
            "name": "Active",
            "value": "Active",
            "description": "Active -  status when a proposal is ready for purchase transaction."
          },
          {
            "name": "Rejected",
            "value": "Rejected",
            "description": "Rejected - status when a proposal's approval has been denied by the approver."
          },
          {
            "name": "Deleted",
            "value": "Deleted",
            "description": "Deleted - status when a proposal has been deleted by the consumer (not visible once deleted)"
          },
          {
            "name": "Expired",
            "value": "Expired",
            "description": "Expired - status when a proposal is beyond its set expiration date."
          },
          {
            "name": "PurchaseInProgress",
            "value": "PurchaseInProgress",
            "description": "PurchaseInProgress - status when a proposal is inprogress on its purchase transaction."
          },
          {
            "name": "Completed",
            "value": "Completed",
            "description": "Completed - status when a proposal is successfully transacted by purchase."
          },
          {
            "name": "Ended",
            "value": "Ended",
            "description": "Ended - status when a proposal is ended by the consumer."
          }
        ]
      }
    },
