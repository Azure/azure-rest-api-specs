          "type": "integer",
          "format": "int64",
          "description": "Out of order ticks allowed in Trill. Event's that have timestamps that are out of order by the specified number of ticks will have their timestamp adjusted. Otherwise if the timestamp is out of order more than the specified ticks, the event is dropped."
        },
        "onCompletedPolicy": {
          "type": "string",
          "description": "This policy determines what Trill will do when a data stream ends. Valid values are either 'Flush', or 'None'."
        },
        "punctuationGenerationPeriod": {
          "type": "integer",
