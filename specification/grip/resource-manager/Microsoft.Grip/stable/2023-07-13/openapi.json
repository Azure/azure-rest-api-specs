      "description": "Kafka source",
      "properties": {
        "offset": {
          "type": "integer",
          "format": "int32",
          "description": "Kafka offset value a consumer will start from when a job is created."
        },
        "enableNestedRecords": {
          "type": "boolean",
          "description": "Determines if events consumed from Kafka should have nested IRecord objects as properties before further processing in GRIP."
        },
        "enableFlattenRecords": {
          "type": "boolean",
          "description": "Determines if events consumed from Kafka should have all nested properties flattened before further processing in GRIP."
        },
        "rebalanceFromCommittedOffset": {
          "type": "boolean",
          "description": "Flag determining if a Kafka consumer should rebalance from a committed offset when a rebalance event is processed at runtime. This will start the consumer from an intermediate offset if enabled."
        },
        "endpoint": {
          "type": "string",
          "description": "Kafka connection endpoint."
        },
        "target": {
          "type": "string",
          "description": "Kafka connection target. This is either 'AZ' or 'region', which is used to build the connection string to connect to a Kafka topic."
        },
        "connectionType": {
          "type": "string",
          "description": "Type of connection for a Kafka topic. This can be a PF local, zonal, or regional type."
        },
        "topic": {
          "type": "string",
          "description": "Kafka topic name."
        },
        "schema": {
          "type": "string",
          "description": "Message schema type for the events consumed from the Kafka topic. This is a C# class path that points to a proto, json, or bond schema."
        },
        "useUnsecureConnection": {
          "type": "boolean",
          "description": "Unsecure connection flag. If true, an HTTP connection is established instead of HTTPS."
        },
        "enableLogging": {
          "type": "boolean",
          "description": "Enable Kafka consumer logging. THis will log all consumer events from Kafka"
        },
        "format": {
          "type": "string",
