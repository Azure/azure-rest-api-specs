{
  "operationId": "ProjectPolicies_CreateOrUpdate",
  "title": "Create or Update Project Policy",
  "parameters": {
    "subscriptionId": "00000000-0000-0000-0000-000000000000",
    "resourceGroupName": "myResourceGroup",
    "accountName": "myAccount",
    "projectName": "myProject",
    "policyName": "team-endpoints",
    "api-version": "2026-07-01-preview",
    "resource": {
      "properties": {
        "policyType": "Egress",
        "defaultAction": "Deny",
        "description": "Project-specific egress policy for team endpoints",
        "rules": [
          {
            "name": "allow-team-api",
            "description": "Allow traffic to team API",
            "match": {
              "host": "api.team-service.contoso.com",
              "path": "/v1/*",
              "methods": ["GET", "POST"]
            },
            "action": "Allow"
          }
        ]
      }
    }
  },
  "responses": {
    "200": {
      "body": {
        "id": "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/myResourceGroup/providers/Microsoft.CognitiveServices/accounts/myAccount/projects/myProject/policies/team-endpoints",
        "name": "team-endpoints",
        "type": "Microsoft.CognitiveServices/accounts/projects/policies",
        "properties": {
          "policyType": "Egress",
          "defaultAction": "Deny",
          "description": "Project-specific egress policy for team endpoints",
          "rules": [
            {
              "name": "allow-team-api",
