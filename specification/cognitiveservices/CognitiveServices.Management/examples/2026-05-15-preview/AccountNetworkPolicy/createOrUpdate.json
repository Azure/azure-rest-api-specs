{
  "operationId": "AccountNetworkPolicies_CreateOrUpdate",
  "title": "Create or Update Account Network Policy",
  "parameters": {
    "subscriptionId": "00000000-0000-0000-0000-000000000000",
    "resourceGroupName": "myResourceGroup",
    "accountName": "myAccount",
    "networkPolicyName": "corporate-baseline",
    "api-version": "2026-05-15-preview",
    "resource": {
      "properties": {
        "policyType": "Egress",
        "mode": "Enforced",
        "defaultAction": "Deny",
        "description": "Corporate baseline egress policy shared across all projects",
        "rules": [
          {
            "name": "allow-openai",
            "description": "Allow traffic to OpenAI API",
            "ruleType": "Fqdn",
            "match": {
              "host": "*.openai.com"
            },
            "action": {
              "actionType": "Allow"
            }
          },
          {
            "name": "inject-auth-header",
            "description": "Inject custom auth header for internal services",
            "ruleType": "Fqdn",
            "match": {
              "host": "*.internal.contoso.com"
            },
            "action": {
              "actionType": "Transform",
              "transformConfig": {
                "headers": [
                  {
                    "name": "X-Internal-Auth",
                    "value": "bearer-token-placeholder",
                    "operation": "Add"
                  }
                ]
              }
            }
          }
        ]
      }
    }
  },
  "responses": {
