              "match": {
                "host": "*.internal.contoso.com"
              },
              "action": {
                "actionType": "Transform",
                "transformConfig": {
                  "headers": [
                    {
                      "name": "X-Internal-Auth",
                      "value": "bearer-token-placeholder",
                      "operation": "Add"
                    }
                  ]
                }
              }
            }
          ],
          "systemRules": [
            {
              "name": "system-allow-azure-storage",
              "description": "Allow Azure Storage for infrastructure operations",
