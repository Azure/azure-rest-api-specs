import "@typespec/rest";
import "@typespec/http";
import "@azure-tools/typespec-azure-core";
import "@azure-tools/typespec-azure-resource-manager";
import "./cloud.tsp";

using Rest;
using Http;
using Azure.ResourceManager;

namespace Anyscale.Platform;

/** Anyscale cloud resource */
@parentResource(Cloud)
@resource("cloudResources")
model CloudResource is TrackedResource<CloudResourceProperties> {
  /** The name of the cloud resource */
  @pattern("^[a-zA-Z0-9]*$")
  @key("cloudResourceName")
  @path
  @segment("cloudResources")
  name: string;
}

/** Properties of the cloud resource */
model CloudResourceProperties {
  /**
   * The cloud resource ID which is used during Anyscale operator bootstrap,
   * generated by Anyscale control plane.
   */
  @visibility(Lifecycle.Read)
  cloudResourceId?: string;

  /** Provider of the cloud resource */
  provider: Provider;

  /** Compute stack of the cloud resource */
  computeStack: ComputeStack;

  /**
   * A fully qualified storage bucket name for cloud storage,
   * e.g. s3://bucket-name, gs://bucket-name, or
   * abfss://bucket-name@account.dfs.core.windows.net.
   */
  cloudStorageBucketName: string;

  /** The cloud storage bucket endpoint */
  cloudStorageBucketEndpoint: string;

  /** The provisioning state of the cloud resource */
  @visibility(Lifecycle.Read)
  provisioningState?: ProvisioningState;
}

/** Cloud provider for the cloud resources */
union Provider {
  string,

  /** Microsoft Azure */
  Azure: "Azure",
}

/** Compute stack associated with the cloud resource */
union ComputeStack {
  string,

  /** Kubernetes */
  K8S: "K8S",
}

/** Cloud resource operations */
@armResourceOperations
interface CloudResources {
  /** Create or update a cloud resource */
  createOrUpdate is ArmResourceCreateOrReplaceAsync<CloudResource>;

  /** Update a cloud resource */
  update is ArmCustomPatchSync<
    CloudResource,
    Azure.ResourceManager.Foundations.ResourceUpdateModel<
      CloudResource,
      CloudResourceProperties
    >
  >;

  /** Delete a cloud resource */
  delete is ArmResourceDeleteWithoutOkAsync<CloudResource>;

  /** Get a cloud resource */
  get is ArmResourceRead<CloudResource>;

  /** List cloud resources by resource group */
  listByResourceGroup is ArmResourceListByParent<CloudResource>;

  /** List cloud resources by subscription */
  listBySubscription is ArmListBySubscription<CloudResource>;
}
