// Exclude LRO polling op getOperationResults from csharp. Baseline SDK did not
// expose it (the op collides with Get on the cluster and autorest.csharp silently
// dropped it). Including it in csharp produces a phantom armProviderSchema entry
// with resourceType ending in /operationResults, colliding on resourceName with
// the real ReplicationProtectionCluster resource.
@@scope(
  Microsoft.RecoveryServices.ReplicationProtectionClusterOperationGroup.getOperationResults,
  "!csharp"
);

