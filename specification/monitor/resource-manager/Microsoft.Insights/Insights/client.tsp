@client({
  name: "CombineClient",
  service: [
    Microsoft.DataCollection,
    Microsoft.PrivateLinkScopes,
    Microsoft.AutoScale,
    Microsoft.ActivityLogs,
    Microsoft.Metrics,
    Microsoft.ServiceDiagnosticsSettings,
