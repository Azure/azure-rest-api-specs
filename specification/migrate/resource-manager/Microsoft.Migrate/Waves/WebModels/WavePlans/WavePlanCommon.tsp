import "@typespec/versioning";
import "@azure-tools/typespec-azure-core";
import "@azure-tools/typespec-azure-resource-manager";
import "../Enums/Enums.tsp";

using TypeSpec.Versioning;
using Azure.Core;
using Azure.ResourceManager;

namespace Microsoft.Migrate;

@doc("The source of a wave plan.")
@added(ApiVersions.v2026_06_01_preview)
union PlanSource {
  @doc("Plan generated by the system.")
  SystemGenerated: "SystemGenerated",

  @doc("Plan imported by the user.")
  Imported: "Imported",

  string,
}

@doc("Artifact Store identity for a wave plan run. Consumers use the artifact ARM id and version id to reference or share the committed artifact and resolve time-bound download access.")
@added(ApiVersions.v2026_06_01_preview)
model ArtifactProperties {
  @doc("The ARM id of the Artifact Store artifact the run's files are committed under.")
  @visibility(Lifecycle.Read)
  artifactId: string;

  @doc("The Artifact Store version id for the run's committed files.")
  @visibility(Lifecycle.Read)
  versionId: string;
}

@doc("Plan-level summary surfaced on the generateWavePlan and getWavePlans responses.")
@added(ApiVersions.v2026_06_01_preview)
model WavePlanSummary {
  @doc("The total number of waves in the plan.")
  @visibility(Lifecycle.Read)
  numberOfWaves: int32;

  @doc("The plan-level overall risk bucket (Low/Medium/High).")
  @visibility(Lifecycle.Read)
  risk: string;

  @doc("The plan-level overall confidence label (Low/Medium/High).")
  @visibility(Lifecycle.Read)
  confidence: string;
}

@doc("Common wave-plan identity fields shared by the getWavePlans list item and the importWavePlan response.")
@added(ApiVersions.v2026_06_01_preview)
model WavePlanListItemBase {
  @doc("The wave-plan name.")
  @visibility(Lifecycle.Read)
  wavePlanName: string;

  @doc("The assessment ARM identifier the plan belongs to.")
  @visibility(Lifecycle.Read)
  assessmentArmId: string;

  @doc("The migration path the plan was generated for.")
  @visibility(Lifecycle.Read)
  migrationPath: string;

  @doc("The provisioning state of the plan.")
  @visibility(Lifecycle.Read)
  provisioningState: ProvisioningState;

  @doc("The source of the plan.")
  @visibility(Lifecycle.Read)
  planSource: PlanSource;

  @doc("The Artifact Store identity (artifactId, versionId) this plan's files are committed under, used to resolve time-bound download access.")
  @visibility(Lifecycle.Read)
  artifactProperties: ArtifactProperties;
}

@doc("A single wave-plan entry in the getWavePlans response.")
@added(ApiVersions.v2026_06_01_preview)
model WavePlanListItem {
  ...WavePlanListItemBase;

  @doc("The plan-level summary (number of waves, risk, confidence).")
  @visibility(Lifecycle.Read)
  summary?: WavePlanSummary;
}
