{
  "swagger": "2.0",
  "info": {
    "title": "McpServerService",
    "description": "Exposes RAG retrieval capabilities as tools over MCP (Model Context Protocol) via a single JSON-RPC 2.0 endpoint.",
    "version": "2024-10-01-preview"
  },
  "schemes": [
    "https"
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "security": [
    {
      "OAuth2Auth": [
        "https://cognitiveservices.azure.com/.default"
      ]
    }
  ],
  "securityDefinitions": {
    "OAuth2Auth": {
      "type": "oauth2",
      "flow": "implicit",
      "authorizationUrl": "https://login.microsoftonline.com/common/oauth2/authorize",
      "scopes": {
        "https://cognitiveservices.azure.com/.default": "Default scope"
      }
    }
  },
  "paths": {
    "/edgeai/mcp": {
      "post": {
        "operationId": "Mcp_Request",
        "summary": "MCP JSON-RPC Endpoint",
        "description": "Single endpoint for all MCP operations. Uses JSON-RPC 2.0 with methods: initialize, tools/list, tools/call. Tools available: search_hybrid, search_vector, search_text, search_image, search_multimodal, get_available_collections.",
        "tags": [
          "Mcp"
        ],
        "parameters": [
          {
            "name": "Mcp-Session-Id",
            "in": "header",
            "type": "string",
            "description": "Session ID from initialize response. Required for tools/list and tools/call."
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/JsonRpcRequest"
            }
          },
          {
            "$ref": "#/parameters/ApiVersionParameter"
          }
        ],
        "responses": {
          "200": {
            "description": "JSON-RPC response.",
            "schema": {
              "$ref": "#/definitions/JsonRpcResponse"
            },
            "headers": {
              "Mcp-Session-Id": {
                "type": "string",
                "description": "Session ID (returned on initialize)."
              }
            }
          },
          "default": {
            "description": "Error response.",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          }
        },
        "x-ms-examples": {
          "MCP Request": {
            "$ref": "./examples/Mcp_Request.json"
          }
        }
      }
    }
  },
  "definitions": {
    "ErrorResponse": {
      "type": "object",
      "properties": {
        "error": {
          "type": "object",
          "properties": {
            "code": {
              "type": "string"
            },
            "message": {
              "type": "string"
            }
          }
        }
      }
    },
    "JsonRpcRequest": {
      "type": "object",
      "required": [
        "jsonrpc",
        "id",
        "method"
      ],
      "properties": {
        "jsonrpc": {
          "type": "string",
          "enum": [
            "2.0"
          ],
          "x-ms-enum": {
            "name": "JsonRpcVersion",
            "modelAsString": true
          }
        },
        "id": {
          "type": "integer",
          "format": "int32"
        },
        "method": {
          "type": "string",
          "enum": [
            "initialize",
            "tools/list",
            "tools/call"
          ],
          "x-ms-enum": {
            "name": "McpMethod",
            "modelAsString": true
          }
        },
        "params": {
          "type": "object",
          "description": "Method-specific parameters."
        }
      }
    },
    "JsonRpcResponse": {
      "type": "object",
      "properties": {
        "jsonrpc": {
          "type": "string",
          "enum": [
            "2.0"
          ],
          "x-ms-enum": {
            "name": "JsonRpcVersion",
            "modelAsString": true
          }
        },
        "id": {
          "type": "integer",
          "format": "int32"
        },
        "result": {
          "type": "object",
          "description": "Method-specific result."
        },
        "error": {
          "$ref": "#/definitions/JsonRpcError"
        }
      }
    },
    "JsonRpcError": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32",
          "description": "-32600 Invalid Request, -32601 Method not found, -32602 Invalid params, -32603 Internal error."
        },
        "message": {
          "type": "string"
        },
        "data": {
          "type": "object"
        }
      }
    },
    "SearchToolRequest": {
      "type": "object",
      "required": [
        "query"
      ],
      "description": "Used by search_hybrid, search_vector, search_text, search_image.",
      "properties": {
        "query": {
          "type": "string"
        },
        "collection_names": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Default: [\"edgeragapp\"]."
        },
        "top_n": {
          "type": "integer",
          "format": "int32",
          "minimum": 1,
          "maximum": 50,
          "default": 5
        },
        "strictness": {
          "type": "integer",
          "format": "int32",
          "minimum": 0,
          "maximum": 5,
          "default": 1
        },
        "filters": {
          "type": "string",
          "description": "Milvus boolean filter expression."
        }
      }
    },
    "MultimodalSearchRequest": {
      "type": "object",
      "required": [
        "query"
      ],
      "description": "Used by search_multimodal.",
      "properties": {
        "query": {
          "type": "string"
        },
        "collection_names": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "top_n": {
          "type": "integer",
          "format": "int32",
          "minimum": 1,
          "maximum": 50,
          "default": 5
        },
        "text_strictness": {
          "type": "integer",
          "format": "int32",
          "minimum": 0,
          "maximum": 5,
          "default": 1
        },
        "image_strictness": {
          "type": "integer",
          "format": "int32",
          "minimum": 0,
          "maximum": 5,
          "default": 1
        },
        "filters": {
          "type": "string"
        }
      }
    },
    "ToolChunkResult": {
      "type": "object",
      "properties": {
        "content": {
          "type": "string"
        },
        "file_path": {
          "type": "string"
        },
        "chunk_id": {
          "type": "string"
        },
        "score": {
          "type": "number",
          "format": "float"
        },
        "page_numbers": {
          "type": "array",
          "items": {
            "type": "integer",
            "format": "int32"
          }
        },
        "vector_type": {
          "type": "string",
          "default": "dense",
          "enum": [
            "dense",
            "sparse",
            "image"
          ],
          "x-ms-enum": {
            "name": "VectorType",
            "modelAsString": true
          }
        }
      }
    },
    "SearchMetadata": {
      "type": "object",
      "properties": {
        "results_number": {
          "type": "integer",
          "format": "int32"
        },
        "search_type": {
          "type": "string",
          "enum": [
            "hybrid_search",
            "vector_search",
            "full_text_search",
            "image_search",
            "multimodal_search"
          ],
          "x-ms-enum": {
            "name": "SearchType",
            "modelAsString": true
          }
        },
        "collection": {
          "type": "string"
        }
      }
    },
    "SearchChunksResponse": {
      "type": "object",
      "description": "Returned by search_hybrid, search_vector, search_text, search_image.",
      "properties": {
        "results": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ToolChunkResult"
          }
        },
        "metadata": {
          "$ref": "#/definitions/SearchMetadata"
        }
      }
    },
    "MultimodalSearchResponse": {
      "type": "object",
      "description": "Returned by search_multimodal.",
      "properties": {
        "text_chunks": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ToolChunkResult"
          }
        },
        "image_chunks": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ToolChunkResult"
          }
        },
        "metadata": {
          "$ref": "#/definitions/SearchMetadata"
        }
      }
    },
    "CollectionInfo": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "CollectionsResponse": {
      "type": "object",
      "description": "Returned by get_available_collections.",
      "properties": {
        "collections": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/CollectionInfo"
          }
        },
        "total_count": {
          "type": "integer",
          "format": "int32"
        }
      }
    }
  },
  "x-ms-parameterized-host": {
    "hostTemplate": "{endpoint}",
    "useSchemePrefix": false,
    "parameters": [
      {
        "name": "endpoint",
        "in": "path",
        "description": "The endpoint URL for the Local Agentic RAG service.",
        "required": true,
        "type": "string",
        "x-ms-skip-url-encoding": true
      }
    ]
  },
  "parameters": {
    "ApiVersionParameter": {
      "name": "api-version",
      "in": "query",
      "required": true,
      "type": "string",
      "description": "The API version to use for this operation."
    }
  }
}