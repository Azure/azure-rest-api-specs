            "description": "Created. MCP validation succeeded.",
            "schema": {
              "$ref": "#/definitions/KnowledgeSource"
            }
          },
          "400": {
            "description": "Bad Request. MCP validation failed."
          },
          "409": {
            "description": "Conflict. Name already exists."
          },
          "422": {
            "description": "Unprocessable Entity. Missing/invalid fields or parameters/kind mismatch."
