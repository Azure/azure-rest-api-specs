  "definitions": {
    "ErrorResponse": {
      "type": "object",
      "properties": {
        "error": {
          "type": "object",
          "properties": {
            "code": {
              "type": "string"
            },
            "message": {
              "type": "string"
            }
          }
        }
      }
    },
    "CreateCollectionRequest": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 2,
          "maxLength": 49,
          "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
          "description": "Lowercase letters, digits, hyphens. 2-49 chars."
        },
        "description": {
          "type": "string",
          "maxLength": 500
        }
      }
    },
    "UpdateCollectionRequest": {
      "type": "object",
      "required": [
        "description"
      ],
      "properties": {
        "description": {
          "type": "string",
          "maxLength": 500
        }
      }
    },
    "Collection": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "created_by": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "active"
          ],
          "x-ms-enum": {
            "name": "CollectionStatus",
            "modelAsString": true
          }
        },
        "last_ingestion_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "CollectionList": {
      "type": "object",
      "properties": {
        "collections": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Collection"
          }
        },
        "total_count": {
          "type": "integer",
          "format": "int32"
        }
      }
    },
    "DeleteCollectionResponse": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "deleted"
          ],
          "x-ms-enum": {
            "name": "DeleteStatus",
            "modelAsString": true
          }
        },
        "deleted_resources": {
          "type": "object",
          "properties": {
            "milvus_collections": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "postgres_tables": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "x-ms-parameterized-host": {
    "hostTemplate": "{endpoint}",
    "useSchemePrefix": false,
    "parameters": [
