import "@typespec/rest";
import "@typespec/http";

using TypeSpec.Rest;
using TypeSpec.Http;

namespace FoundryLocal.AgenticRAG;

// ──── Inference enums ────

/** The role of the user making an inference request. */
union UserRole {
  string,

  /** Developer role with full parameter control. */
  dev: "dev",

  /** Standard user role with developer-configured settings. */
  user: "user",
}

/** The role of a participant in a chat conversation. */
union ChatRole {
  string,

  /** A system message providing instructions. */
  system: "system",

  /** A message from the user. */
  user: "user",

  /** A message from the assistant. */
  assistant: "assistant",
}

/** The type of data source used for retrieval. */
union DataSourceType {
  string,

  /** A Milvus vector database data source. */
  milvus: "milvus",
}

/** The type of search query to perform. */
union QueryType {
  string,

  /** A hybrid search combining dense and sparse retrieval. */
  hybrid_search: "hybrid_search",

  /** A vector similarity search. */
  vector_search: "vector_search",

  /** A full text search. */
  full_text_search: "full_text_search",

  /** A hybrid multimodal search across text and images. */
  hybrid_multimodal_search: "hybrid_multimodal_search",
}

/** The role for assistant responses. */
union AssistantRole {
  string,

  /** The assistant role. */
  assistant: "assistant",
}

// ──── Inference models ────

/** Request body for a RAG chat completion. */
model RagChatRequest {
  /** The list of chat messages forming the conversation. */
  messages: ChatMessage[];

  /** Sampling temperature for the model response. */
  @maxValue(1)
  temperature?: float32 = 0.7;

  /** Nucleus sampling probability for the model response. */
  @encodedName("application/json", "top_p")
  topP?: float32 = 0.1;

  /** Whether to format the response as Markdown. */
  isMarkdown?: boolean;

  /** Data sources to query for retrieval-augmented generation. */
  @encodedName("application/json", "data_sources")
  dataSources?: DataSource[];
}

/** A single message in a chat conversation. */
model ChatMessage {
  /** The role of the message author. */
  role: ChatRole;

  /** The content of the message. */
  content: string;
}

/** A data source configuration for retrieval. */
model DataSource {
  /** The type of the data source. */
  type?: DataSourceType;

  /** Configuration parameters for the Milvus data source. */
  parameters?: MilvusDataSourceParameters;
}

/** Configuration parameters for a Milvus data source. */
model MilvusDataSourceParameters {
  /** Milvus endpoint. Use empty string. */
  endpoint?: string = "";

  /** Collection to query. */
  @encodedName("application/json", "index_name")
  indexName?: string = "edgeragapp";

  /** Text strictness level for filtering results. */
  @maxValue(5)
  @minValue(1)
  @encodedName("application/json", "text_strictness")
  textStrictness?: int32 = 2;

  /** Image strictness level for filtering results. */
  @maxValue(5)
  @minValue(1)
  @encodedName("application/json", "image_strictness")
  imageStrictness?: int32 = 1;

  /** Maximum number of documents to retrieve. */
  #suppress "@azure-tools/typespec-azure-core/casing-style" "topNDocuments follows camelCase with acronym N"
  @encodedName("application/json", "top_n_documents")
  topNDocuments?: int32 = 5;

  /** The type of query to perform. */
  @encodedName("application/json", "query_type")
  queryType?: QueryType = QueryType.hybrid_search;
}

/** Response from a chat completion request. */
model ChatCompletionResponse {
  /** The unique identifier of the completion response. */
  id?: string;

  /** Unix epoch timestamp of when the response was created. */
  created?: int64;

  /** The list of completion choices. */
  choices?: Choice[];
}

/** A single completion choice in a chat response. */
model Choice {
  /** Content filter results for this choice. */
  #suppress "@azure-tools/typespec-azure-core/no-unknown" "Content filter results have dynamic structure"
  #suppress "@azure-tools/typespec-azure-core/bad-record-type" "Content filter results have dynamic structure"
  @encodedName("application/json", "content_filter_results")
  contentFilterResults?: Record<unknown>;

  /** The assistant message for this choice. */
  message?: AssistantMessage;
}

/** A message generated by the assistant. */
model AssistantMessage {
  /** The text content of the message. */
  content?: string;

  /** The role of the message author. */
  role?: AssistantRole;

  /** Context information including citations. */
  context?: AssistantMessageContext;

  /** The type of search used to retrieve context. */
  @encodedName("application/json", "search_type")
  searchType?: string;

  /** The number of documents retrieved. */
  #suppress "@azure-tools/typespec-azure-core/casing-style" "topNDocuments follows camelCase with acronym N"
  @encodedName("application/json", "top_n_documents")
  topNDocuments?: int32;

  /** The text strictness level used for retrieval. */
  @encodedName("application/json", "text_strictness")
  textStrictness?: int32;

  /** The search results used to generate the response. */
  @encodedName("application/json", "search_results")
  searchResults?: AssistantMessageSearchResults;
}

/** Context information attached to an assistant message. */
model AssistantMessageContext {
  /** The list of citations referenced in the response. */
  citations?: Citation[];
}

/** A citation referencing a source document chunk. */
model Citation {
  /** The file path of the cited document. */
  filepath?: string;

  /** The identifier of the cited chunk. */
  @encodedName("application/json", "chunk_id")
  chunkId?: string;

  /** The relevance score of the citation. */
  score?: float32;

  /** The content of the cited chunk. */
  content?: string;

  /** The page numbers referenced by the citation. */
  @encodedName("application/json", "page_numbers")
  pageNumbers?: int32[];
}

/** Search results grouped by retrieval type. */
model AssistantMessageSearchResults {
  /** Dense vector search results. */
  dense?: Record<string>[];

  /** Sparse text search results. */
  sparse?: Record<string>[];

  /** Image search results. */
  image?: Record<string>[];
}

/** Request body for a model-only chat completion without retrieval. */
model ModelOnlyChatRequest {
  /** The list of chat messages forming the conversation. */
  messages: ChatMessage[];

  /** Sampling temperature for the model response. */
  @maxValue(1)
  temperature?: float32 = 0.7;

  /** Nucleus sampling probability for the model response. */
  @encodedName("application/json", "top_p")
  topP?: float32 = 0.1;
}
