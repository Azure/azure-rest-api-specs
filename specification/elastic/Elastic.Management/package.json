    "@typespec/compiler": "latest",
    "@typespec/http": "latest",
    "@typespec/openapi": "latest",
    "@typespec/rest": "latest",
    "@typespec/versioning": "latest"
  },
  "keywords": [
    "typespec",
    "azure",
    "elastic",
    "api"
  ],
  "dependencies": {
    "@azure-tools/typespec-azure-rulesets": "^0.65.0"
