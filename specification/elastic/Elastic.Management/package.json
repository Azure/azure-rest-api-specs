{
  "name": "elastic-management-typespec",
  "version": "1.0.0",
  "description": "TypeSpec definition for Azure Elastic Management API",
  "main": "main.tsp",
  "scripts": {
    "build": "npx tsp compile .",
    "watch": "npx tsp compile . --watch"
  },
  "devDependencies": {
    "@azure-tools/typespec-autorest": "latest",
    "@azure-tools/typespec-azure-core": "latest",
    "@azure-tools/typespec-azure-resource-manager": "latest",
