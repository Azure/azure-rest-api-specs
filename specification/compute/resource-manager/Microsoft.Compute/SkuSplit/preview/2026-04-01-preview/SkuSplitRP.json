  "definitions": {
    "SkuMixPlacementAllocationStrategy": {
      "type": "string",
      "description": "Allocation strategy for determining the optimal SKU split.",
      "enum": [
        "LowestPrice",
        "Prioritized",
        "EvictionOptimized"
      ],
      "x-ms-enum": {
        "name": "SkuMixPlacementAllocationStrategy",
        "modelAsString": true,
        "values": [
          {
            "name": "LowestPrice",
            "value": "LowestPrice",
            "description": "VMs allocated to optimize for lowest price."
          },
          {
            "name": "Prioritized",
            "value": "Prioritized",
            "description": "VMs allocated based on customer-specified rank for each VM size."
          },
          {
            "name": "EvictionOptimized",
            "value": "EvictionOptimized",
            "description": "VMs allocated to optimize for lowest eviction rate (Spot only)."
          }
        ]
      }
    },
