          "$ref": "../../../../../../common-types/resource-management/v6/types.json#/definitions/ProxyResource"
        }
      ]
    },
    "SkuMixPlacementCapacityProfile": {
      "type": "object",
      "description": "Capacity-related properties for the placement request.",
      "properties": {
        "capacity": {
          "type": "integer",
          "format": "int32",
          "description": "The capacity to run the workload. For VMs: [1..10,000]. For vCPUs: [1..100,000]."
        },
        "capacityType": {
          "$ref": "#/definitions/SkuMixPlacementCapacityType",
          "description": "The unit type for the capacity value."
        },
        "priority": {
          "$ref": "#/definitions/SkuMixPlacementPriority",
          "description": "The priority of the VMs to allocate."
        },
        "spotPriorityProfile": {
          "$ref": "#/definitions/SkuMixPlacementSpotPriorityProfile",
          "description": "Required when priority is Spot. Contains spot-specific configuration."
        },
        "allocationStrategy": {
          "$ref": "#/definitions/SkuMixPlacementAllocationStrategy",
          "description": "The allocation strategy for determining the optimal SKU split."
        },
        "osType": {
          "$ref": "#/definitions/SkuMixPlacementOSType",
          "description": "The OS type. Required when allocationStrategy is LowestPrice because pricing varies by OS."
        },
        "zoneAllocationPolicy": {
          "$ref": "#/definitions/SkuMixPlacementZoneAllocationPolicy",
          "description": "Zone allocation policy. Default: BestEffortBalanced."
        }
      },
      "required": [
        "capacity",
        "capacityType",
        "priority",
        "allocationStrategy"
      ]
    },
