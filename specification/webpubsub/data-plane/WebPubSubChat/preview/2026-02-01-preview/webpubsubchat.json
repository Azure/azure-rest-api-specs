    "ChatConversation": {
      "type": "object",
      "description": "Chat conversation identifier.",
      "properties": {
        "conversationId": {
          "type": "string",
          "description": "Conversation identifier.",
          "pattern": "^c\\.[A-Za-z0-9_-]{1,64}(?:\\.[A-Za-z0-9_-]{1,64})?$"
        },
        "roomId": {
          "type": "string",
          "description": "Room identifier.",
          "pattern": "^[A-Za-z0-9_-]{1,64}$"
        },
        "topicId": {
          "type": "string",
          "description": "Topic identifier.",
          "pattern": "^[A-Za-z0-9_-]{1,64}$"
        }
      }
    },
    "ChatConversationInfo": {
      "type": "object",
      "description": "Represents conversation information.",
      "properties": {
        "conversationId": {
          "type": "string",
          "description": "Conversation identifier."
        },
        "parentRoom": {
          "type": "string",
          "description": "Parent room identifier."
        }
      },
      "required": [
        "conversationId",
        "parentRoom"
      ]
    },
    "ChatMessageInfo": {
      "type": "object",
      "description": "Chat message information.",
      "properties": {
        "messageId": {
          "type": "string",
          "description": "Message identifier."
        },
        "createdBy": {
          "type": "string",
          "description": "User who created the message."
        },
        "content": {
          "$ref": "#/definitions/ContentBody",
          "description": "Message content."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the message was created."
        }
      }
    },
    "ChatRoleInfo": {
      "type": "object",
      "description": "Represents role information.\nA role must contain either user permissions or room permissions, but not both.",
      "properties": {
        "role": {
          "type": "string",
          "description": "Role name."
        },
        "permissions": {
          "type": "array",
          "description": "Permissions associated with the role. Do not mix user permissions and room permissions in one role.",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "role",
        "permissions"
      ]
    },
    "ChatRoomInfo": {
      "type": "object",
      "description": "Represents room information.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Room identifier."
        },
        "title": {
          "type": "string",
          "description": "Room title."
        },
        "defaultConversation": {
          "type": "string",
          "description": "Default conversation ID for this room."
        }
      },
      "required": [
        "id",
        "title",
        "defaultConversation"
      ]
    },
    "ChatRoomMember": {
      "type": "object",
      "description": "Represents a room member.",
      "properties": {
        "userId": {
          "type": "string",
          "description": "User ID of the member."
        },
        "role": {
          "type": "string",
          "description": "Room role assigned to the user within this room."
        }
      },
      "required": [
        "userId",
        "role"
      ]
    },
    "ChatUserProfile": {
      "type": "object",
      "description": "Represents a user profile in the chat system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "User identifier."
        },
        "nickname": {
          "type": "string",
          "description": "User's display nickname."
        },
        "role": {
          "type": "string",
          "description": "Global user role assigned to the user."
        }
      },
      "required": [
        "id",
        "nickname"
      ]
    },
    "ContentBody": {
      "type": "object",
      "description": "Message content body.",
      "properties": {
        "text": {
          "type": "string",
          "description": "Text content."
        },
        "binary": {
          "type": "string",
          "format": "byte",
          "description": "Binary content (base64 encoded)."
        }
      }
    },
    "CreateChatRoomRequest": {
      "type": "object",
      "description": "Request to create a new room.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Optional room ID. If not provided, one will be generated."
        },
        "title": {
          "type": "string",
          "description": "Room title."
        }
      },
      "required": [
        "title"
      ]
    },
    "CreateOrUpdateChatRoleInfoRequest": {
      "type": "object",
      "description": "Request to create or update a role.",
      "properties": {
        "permissions": {
          "type": "array",
