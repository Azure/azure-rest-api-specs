          "items": {
            "$ref": "#/definitions/ChatRoleInfo"
          }
        },
        "nextUrl": {
          "type": "string",
          "description": "URL to fetch the next page of roles."
        }
      },
      "required": [
        "roles"
      ]
    },
    "UpdateChatMessageRequest": {
      "type": "object",
      "description": "Request to update a message.\nContains parts of MessageInfo excluding conversation (which is already known from the URL).",
      "properties": {
        "createdBy": {
          "type": "string",
          "description": "Optional. The user who created the message."
        },
        "content": {
          "$ref": "#/definitions/ContentBody",
          "description": "Message content."
        }
      }
    },
    "UpdateChatRoomMemberRequest": {
      "type": "object",
      "description": "Request to update a room member.",
      "properties": {
        "role": {
          "type": "string",
          "description": "Room role assigned to the user within this room."
        }
      },
      "required": [
        "role"
      ]
